# Domain and ports
DOMAIN=localhost
HTTP_PORT=80
HTTPS_PORT=443
TZ=UTC

# Core secrets
DB_USER=worklenz
DB_PASSWORD=CHANGE_THIS_DB_PASSWORD
DB_NAME=worklenz_db
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET
COOKIE_SECRET=CHANGE_THIS_COOKIE_SECRET
JWT_SECRET=CHANGE_THIS_JWT_SECRET

# MongoDB URI (used by backend)
MONGO_URI=mongodb://worklenz:CHANGE_THIS_DB_PASSWORD@mongo:27017/worklenz_db?authSource=admin

# Frontend/runtime URLs
FRONTEND_URL=https://localhost
VITE_API_URL=https://localhost/api
VITE_SOCKET_URL=https://localhost
VITE_APP_TITLE=Worklenz
VITE_APP_ENV=production
VITE_ENABLE_RECAPTCHA=false
VITE_RECAPTCHA_SITE_KEY=
VITE_ENABLE_GOOGLE_LOGIN=false
VITE_ENABLE_SURVEY_MODAL=false

# CORS
SERVER_CORS=*
SOCKET_IO_CORS=https://localhost

# Redis
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_DB=0

# MinIO/S3 defaults
STORAGE_PROVIDER=s3
AWS_REGION=us-east-1
AWS_BUCKET=worklenz-bucket
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=CHANGE_THIS_MINIO_PASSWORD
S3_URL=http://minio:9000

# Optional Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Optional mail/security
ENABLE_EMAIL_CRONJOBS=false
CONTACT_US_EMAIL=
GOOGLE_CAPTCHA_SECRET_KEY=
GOOGLE_CAPTCHA_PASS_SCORE=0.8
